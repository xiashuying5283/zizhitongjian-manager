{
  "name": "tongjianrenwu",
  "version": "1.0.0",
  "description": "资治通鉴人物数据库管理后台",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc && cd frontend && npm run build",
    "start": "node dist/server.js",
    "dev": "concurrently -n \"后端,前端\" -c \"blue,green\" \"npm:dev:server\" \"npm:dev:frontend\"",
    "dev:server": "ts-node src/server.ts",
    "dev:frontend": "cd frontend && npm run dev",
    "install:all": "npm install && cd frontend && npm install"
  },
  "dependencies": {
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "openai": "^4.24.0",
    "pg": "^8.11.3",
    "pinyin-pro": "^3.18.2"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@types/pg": "^8.10.9",
    "concurrently": "^9.2.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.3"
  },
  "private": true
}
